RAW_TOPIC=raw_flows
PROCESSED_TOPIC=processed_flows

KAFKA_INTERNAL_SERVER=kafka:29092
KAFKA_HOST_PORT=9092

INFLUXDB_URL=http://influxdb:8086
INFLUXDB_ORG=nids_org
INFLUXDB_BUCKET=nids_bucket
INFLUXDB_TOKEN=nids-super-secret-token-12345
INFLUXDB_USERNAME=admin
INFLUXDB_PASSWORD=adminpassword

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

INFERENCE_GROUP_ID=inference_group_docker
INFERENCE_DEVICE=auto
CHUNK_SIZE=256
SEQ_TIME_STEPS=10
GRAPH_WINDOW_SIZE=50
GRAPH_MAX_DT=30.0

KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_ENABLE_AUTO_COMMIT=true
KAFKA_CONNECT_RETRIES=30
KAFKA_RETRY_BACKOFF_SECONDS=2.0

SPARK_STARTING_OFFSETS=earliest
SPARK_CHECKPOINT=file:///app/checkpoints/spark_checkpoints_cciot
SPARK_WORKER_LOG=/tmp/spark_worker_debug.log
SPARK_KAFKA_PACKAGE=org.apache.spark:spark-sql-kafka-0-10_2.13:4.0.1
