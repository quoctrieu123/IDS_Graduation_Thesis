# Editors and operating systems
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.code-workspace
*.swp
*.swo
*~
.DS_Store
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Logs and temporary files
# -----------------------------------------------------------------------------
*.log
*.tmp
*.temp
*.bak
*.orig
spark_worker_debug.log

# -----------------------------------------------------------------------------
# Large raw and preprocessed datasets
#
# Small preprocessing artifacts such as *.pkl and *.joblib are intentionally
# retained because they are required to reproduce preprocessing and inference.
# -----------------------------------------------------------------------------
*.csv
*.parquet
*.feather
*.arrow
*.npy
*.npz
*.h5
*.hdf5

# -----------------------------------------------------------------------------
# Experiment outputs and framework caches
#
# Trained models under each use case's model_saved/ directory are intentionally
# retained. Use Git LFS for model binaries if the repository is hosted remotely.
# -----------------------------------------------------------------------------
catboost_info/
wandb/
runs/
lightning_logs/
mlruns/
saved_models_xids/

# -----------------------------------------------------------------------------
# Spark, Kafka, and local deployment state
# -----------------------------------------------------------------------------
spark_checkpoints*/
docker_deployment/spark_checkpoints_cciot/
spark-warehouse/
metastore_db/
derby.log
*.crc

# Local service data if bind-mounted during development
docker_deployment/influxdb_data/
docker_deployment/grafana_data/
docker_deployment/kafka_data/
docker_deployment/zookeeper_data/

# -----------------------------------------------------------------------------
# Generated reports and profiling output
